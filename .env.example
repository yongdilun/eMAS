# Project root `.env` — used only for Docker Compose substitution + a few overrides.
# Copy to `.env` and edit. Never commit `.env`.
#
# App-specific variables (LLM, LangSmith, JWT, ADMIN_API_KEY, models, timeouts, etc.)
# are loaded from:
#   - ./emas/.env          → go-api container (DB_* overridden below for Docker)
#   - ./factory-agent/.env → factory-agent container (DB/Go/Redis URLs overridden for Docker)

# --- Required for Compose (MySQL service + DATABASE_URL for factory-agent) ---
MYSQL_DATABASE=emas_db
MYSQL_USER=emas
MYSQL_PASSWORD=change-me-emas-user
MYSQL_ROOT_PASSWORD=change-me-root

# Match emas/.env DB_NAME if you use a non-default name, e.g. MYSQL_DATABASE=emas

# --- Go API override (optional; defaults match emas/.env) ---
SERVER_ADDR=:8080

# --- Frontend build args (paths only; browser talks to nginx on :80) ---
VITE_API_BASE_URL=/api/v1
VITE_FACTORY_AGENT_BASE_URL=/agent

# --- Factory agent mode (optional) ---
# Passed into the factory-agent container. Defaults to production in docker-compose.yml (Gemini: use PRODUCTION_* in factory-agent\.env).
# APP_MODE=development

# --- Redis (optional) ---
# Default empty: factory-agent/.env may set localhost Redis; Compose forces override.
# Without Redis profile: leave empty so the agent does not use Redis in Docker.
# With `docker compose --profile with-redis up -d`, set:
# REDIS_URL=redis://redis:6379/0
REDIS_URL=
