{
  "id": "SO-029",
  "title": "Go API 500 mid-run",
  "risk": "A backend 500 during commit can be hidden behind generic success copy, missing audit rows, or stale terminal UI.",
  "prompt": "Change all high priority jobs to medium.",
  "initial_state": {
    "jobs": [
      {
        "id": "JOB-SO029-HIGH-01",
        "priority": "high",
        "status": "open"
      },
      {
        "id": "JOB-SO029-LOW-01",
        "priority": "low",
        "status": "open"
      }
    ],
    "approvals": [],
    "audit_rows": [],
    "failure_injection": {
      "component": "go_api",
      "when": "commit",
      "status_code": 500,
      "message": "database unavailable"
    }
  },
  "expected_intents": [
    {
      "intent_id": "SO-029-I1",
      "route": "tool.write.jobs.bulk_update_priority",
      "filter": {
        "priority": "high"
      },
      "new_values": {
        "priority": "medium"
      },
      "source_row_ids": [
        "JOB-SO029-HIGH-01"
      ]
    }
  ],
  "expected_approvals": [
    {
      "approval_id": "approval-so-029-1",
      "intent_id": "SO-029-I1",
      "decision": "accepted",
      "row_ids": [
        "JOB-SO029-HIGH-01"
      ],
      "row_count": 1,
      "expected_commit_result": "failed_500"
    }
  ],
  "expected_intermediate_states": [
    {
      "after": "commit failure",
      "session_phase": "FAILED",
      "pending_approval_id": null,
      "commit_error": "go_api_500",
      "forbidden": [
        "audit_success_row",
        "final_success_response",
        "job_priority_changed"
      ]
    }
  ],
  "expected_final_state": {
    "session_phase": "FAILED",
    "jobs": [
      {
        "id": "JOB-SO029-HIGH-01",
        "priority": "high"
      },
      {
        "id": "JOB-SO029-LOW-01",
        "priority": "low"
      }
    ],
    "pending_approval_id": null
  },
  "expected_audit_rows": [],
  "expected_timeline": [
    {
      "event": "operation_started"
    },
    {
      "event": "approval_requested",
      "approval_id": "approval-so-029-1"
    },
    {
      "event": "approval_decided",
      "approval_id": "approval-so-029-1",
      "decision": "accepted"
    },
    {
      "event": "commit_started",
      "approval_id": "approval-so-029-1"
    },
    {
      "event": "backend_request_failed_before_audit",
      "approval_id": "approval-so-029-1",
      "error": "go_api_500"
    },
    {
      "event": "operation_failed",
      "reason": "go_api_500"
    }
  ],
  "expected_sse_or_snapshot": {
    "terminal": {
      "status": "FAILED",
      "pending_approval_id": null,
      "error": "go_api_500",
      "must_not_include_events": [
        "operation_completed",
        "final_success_response"
      ]
    }
  },
  "expected_final_response": {
    "allowed_after": "operation_failed go_api_500",
    "must_include": [
      "could not complete",
      "database unavailable",
      "Please retry"
    ],
    "must_not_include": [
      "1 high priority job changed to medium",
      "Run complete",
      "all requested changes completed"
    ]
  },
  "expected_ui": {
    "approval_cards_in_order": [
      "approval-so-029-1"
    ],
    "must_show": [
      "could not complete",
      "database unavailable",
      "Please retry"
    ],
    "must_not_show": [
      "Run complete",
      "1 high priority job changed to medium"
    ]
  },
  "expected_unchanged_rows": [
    {
      "id": "JOB-SO029-HIGH-01",
      "priority": "high"
    },
    {
      "id": "JOB-SO029-LOW-01",
      "priority": "low"
    }
  ],
  "invariants": [
    "backend_error_blocks_success",
    "failed_commit_does_not_mutate_rows",
    "backend_error_creates_no_audit_rows",
    "no_generic_error_on_expected_backend_failure",
    "final_summary_matches_commits"
  ],
  "required_layers": [
    "seeded_full_stack",
    "release"
  ],
  "weakness_from_phase0": "Seeded and release tests can pass on final visibility; this oracle forces a Go API 500 to produce failed state, no data-integrity audit rows, unchanged rows, and no success copy.",
  "phase13_quality_gate": {
    "real_product_bug_caught": "A Go API 500 after approval can leave rows unchanged while timeline or visible UI still shows generic/stale success and audit evidence implies a commit happened.",
    "existing_test_that_would_miss_it": "eMas Front/e2e/specs/chat-fixtures.spec.js::plan creation 503 shows plan-start failure only; it does not cover approved mid-run commit failure, DB rows, audit rows, approval ids, or stale post-approval plan text.",
    "lowest_useful_layer": "seeded_full_stack",
    "browser_coverage_required": true,
    "real_langgraph_coverage_required": false,
    "required_positive_evidence": [
      "approval id is approved",
      "session and snapshot are FAILED",
      "target job and all seeded job rows remain unchanged",
      "data-integrity audit rows are empty",
      "timeline has failed tool_result and session_failed",
      "visible UI explains database unavailable and asks the operator to retry"
    ],
    "required_forbidden_stale_evidence": [
      "Run complete",
      "stale Success plan text",
      "priority changed to medium",
      "all requested changes completed",
      "data-integrity audit rows"
    ],
    "coverage_category": "canonical"
  },
  "executable_enforcement": {
    "pytest": [
      "factory-agent/tests/test_snapshot_timeline_final_response_contract.py::test_all_stateful_oracle_files_have_executable_snapshot_final_response_contract"
    ],
    "playwright": [
      "eMas Front/e2e/specs/full-stack-data-integrity.spec.js::SO-029 Go API 500 mid-run fails safely without mutation or audit rows"
    ],
    "visible_dom_assertions_required": true,
    "manual_prompt_regression": [],
    "tracker": "docs/qa/STATEFUL_ORACLE_TESTING_TRACK.md#phase-12-executable-enforcement-closure"
  }
}
